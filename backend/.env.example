# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Origin allowed to call this API with credentials (the frontend dev server).
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas or local).
PROD_DATABASE_URL=mongodb://127.0.0.1:27017/ethara

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be IDENTICAL to the frontend's TOKEN_SECRET so the Next.js middleware can
# verify the JWT cookies this server issues.
TOKEN_SECRET=replace-with-a-long-random-secret

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=no-reply@ethara.ai

# Base URL used to build verification / password-reset links in emails.
# Point this at the FRONTEND so the links open the UI.
DOMAIN_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
